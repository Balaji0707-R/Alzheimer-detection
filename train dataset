import os
import nibabel as nib
import numpy as np
import cv2

train_path = "/kaggle/input/datasets/velavansekar/adni-mri-alzheimer-dataset-train-val-test-split/train/train"
save_path = "/kaggle/working/processed/train"

IMG_SIZE = 224

for cls in ["CN", "MCI", "AD"]:
    os.makedirs(os.path.join(save_path, cls), exist_ok=True)

def process_and_save(file_path, label):
    img = nib.load(file_path)
    data = img.get_fdata()

    total_slices = data.shape[2]

    center = total_slices // 2
    num_slices = 20

    start = center - num_slices // 2
    end = center + num_slices // 2

    for i in range(start, end):
        slice_img = data[:, :, i]

        slice_img = (slice_img - np.min(slice_img)) / (np.max(slice_img) - np.min(slice_img))
        slice_img = cv2.resize(slice_img, (IMG_SIZE, IMG_SIZE))

        # ✅ FIX: convert to 3 channel
        slice_img = np.stack([slice_img]*3, axis=-1)

        slice_img = (slice_img * 255).astype(np.uint8)

        filename = os.path.basename(file_path).replace(".nii", f"_{i}.png")
        save_file = os.path.join(save_path, label, filename)



        
        cv2.imwrite(save_file, slice_img)

for category in os.listdir(train_path):
    for file in os.listdir(os.path.join(train_path, category)):
        try:
            process_and_save(os.path.join(train_path, category, file), category)
        except:
            continue

print("Train dataset ready ✅")
